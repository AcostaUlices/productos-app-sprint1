generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  categoria   String
  precio      Float
  stock       Int
  descripcion String?
  creadoEn    DateTime @default(now())
}
